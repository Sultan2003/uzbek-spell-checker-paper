# Large local corpora and compressed corpora
uz.txt
uz.txt.xz
*.xz
*.zst
*.gz

# Raw datasets: keep placeholders only
dataset/raw/*
!dataset/raw/.gitkeep

# Processed/generated large data artifacts: keep placeholders only
dataset/processed/*.csv
dataset/processed/*.json
dataset/generated_errors/*.csv

# Models and checkpoints
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
